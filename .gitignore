# Kopi Pagi Pagi Website - .gitignore
# Static HTML/CSS/JS website with Google Sheets integration

# ============================================
# DEVELOPMENT & EDITOR FILES
# ============================================

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ============================================
# OPERATING SYSTEM FILES
# ============================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# ============================================
# BUILD & DEPENDENCY FILES
# ============================================

# Node modules (if you add build tools later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package lock files (keep one, ignore others)
package-lock.json
yarn.lock

# ============================================
# TEMPORARY & CACHE FILES
# ============================================

# General temp files
*.tmp
*.temp
*.cache
*.log

# Image optimization temp files
*.webp.bak
*.png.bak
*.jpg.bak

# ============================================
# SENSITIVE & PRIVATE FILES
# ============================================

# Environment variables & secrets
.env
.env.local
.env.production
.env.*.local
secrets.json

# Google API keys (if stored locally)
google-credentials.json
service-account-key.json

# ============================================
# BACKUP & ARCHIVE FILES
# ============================================

# Backup files
*.bak
*.backup
*.old
*-backup/
*-old/

# Archive files
*.zip
*.tar
*.gz
*.rar
*.7z

# ============================================
# PROJECT-SPECIFIC EXCLUSIONS
# ============================================

# Original PNG files (we use WebP)
# Uncomment if you want to keep only WebP in git
# images/*.png
# !images/logo.png

# Local development versions
*-local.html
*-test.html
*-draft.html

# Documentation drafts (keep published docs only)
# docs/drafts/
# docs/*-draft.md

# ============================================
# DEPLOYMENT & CI/CD
# ============================================

# Build output directories
dist/
build/
out/

# Cloudflare Workers/Pages local dev
.wrangler/
wrangler.toml

# ============================================
# LOGS & DEBUG
# ============================================

# Debug logs
debug.log
error.log
*.log

# ============================================
# OPTIONAL: LARGE ASSETS
# ============================================

# Uncomment if you have large assets that should not be in Git
# Use Git LFS or host on Google Drive instead
# *.mp4
# *.mov
# *.avi
# large-files/
